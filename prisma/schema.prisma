// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 권한 설정 ---
enum UserRole {
  USER        // 일반 학생
  INSTRUCTOR  // 강사
  ADMIN       // 관리자
}

// --- 1. 회원 (Auth.js 호환 포함) ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?   // Hashed
  role          UserRole  @default(USER)
  image         String?
  createdAt     DateTime  @default(now())
  
  // Relations
  orders        Order[]     // 주문 내역
  progresses    Progress[]  // 수강 진도
  posts         Post[]      // 작성한 게시글(Q&A, 후기)
  userCoupons   UserCoupon[]
  ownedCourses  Course[]    @relation("InstructorCourses") // 강사일 경우
  
  submissions   Submission[]  // 온라인 시험 제출 내역
  certificates  Certificate[] // 수료증 발급 내역
  accessLogs    AccessLog[]   // 보안 및 기기 접속 로그
  assignmentSubmissions AssignmentSubmission[] // 과제 제출 내역
}

// --- 2. 강좌 및 강의 ---
model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  courses Course[]
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  thumbnail   String?
  price       Int      @default(0)
  isPublished Boolean  @default(false)
  
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  
  instructorId String
  instructor   User     @relation("InstructorCourses", fields: [instructorId], references: [id])

  lessons      Lesson[]
  orderItems   OrderItem[]  // 주문 항목 연동 (기존 orders 제거)
  posts        Post[]
  exams        Exam[]       // 시험 정보 연동
  certificates Certificate[] // 수료증 발급 연동
  assignments  Assignment[]  // 과제 정보 연동
  createdAt    DateTime @default(now())
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  videoUrl    String   // 비디오 스트리밍 주소
  duration    Int      @default(0) // 초 단위 길이
  order       Int      // 강의 순서
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  progresses  Progress[]
}

// --- 3. 수강 진도율 (LMS 핵심) ---
model Progress {
  id          String   @id @default(cuid())
  isCompleted Boolean  @default(false)
  lastPosition Int     @default(0) // 마지막 시청 위치 (초)
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  updatedAt   DateTime @updatedAt
  @@unique([userId, lessonId]) // 한 학생이 한 강의에 대해 하나의 진도만 가짐
}

// --- 4. 주문 및 결제 (포트원 연동 대비) ---
enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Order {
  id            String      @id @default(cuid())
  amount        Int
  status        OrderStatus @default(PENDING)
  paymentId     String?     @unique // 포트원 결제 고유 번호 (merchant_uid)
  
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  
  orderItems    OrderItem[] // 1:N 주문 상세 항목으로 변경
  
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id        String   @id @default(cuid())
  price     Int      // 구매 시점의 단가
  quantity  Int      @default(1)
  
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id])
  
  bookId    String?
  book      Book?    @relation(fields: [bookId], references: [id])
}

// --- 5. 교재 (도서 쇼핑몰 확장) ---
model Book {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  price       Int      @default(0)
  thumbnail   String?
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  
  orderItems  OrderItem[]
}

// --- 6. 쿠폰 시스템 ---
model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Int      // 할인 금액 또는 비율
  isPercent   Boolean  @default(false)
  expiryDate  DateTime
  
  userCoupons UserCoupon[]
}

model UserCoupon {
  id        String   @id @default(cuid())
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
}

// --- 7. 커뮤니티 (Q&A, 수강후기) ---
enum PostType {
  QNA
  REVIEW
}

model Post {
  id        String   @id @default(cuid())
  type      PostType
  title     String
  content   String   @db.Text
  rating    Int?     // 후기일 경우 별점 (1~5)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  
  createdAt DateTime @default(now())
}

// --- 8. 온라인 시험 시스템 ---
model Exam {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  duration    Int      @default(60) // 제한 시간 (분)
  passingScore Int     @default(60) // 합격 기준 점수 (100점 만점 기준 등)
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  questions   Question[]
  submissions Submission[]
  createdAt   DateTime @default(now())
}

enum QuestionType {
  OX
  MULTIPLE_CHOICE
  SHORT_ANSWER
  DESCRIPTIVE
}

model Question {
  id            String       @id @default(cuid())
  type          QuestionType @default(MULTIPLE_CHOICE)
  content       String       @db.Text
  score         Int          @default(10) // 문제 배점
  correctAnswer String?      @db.Text    // 단답형 정답 혹은 서술형 예시 가이드
  
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  
  choices   Choice[]
}

model Choice {
  id          String   @id @default(cuid())
  content     String
  isCorrect   Boolean  @default(false)
  
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Submission {
  id          String   @id @default(cuid())
  score       Int
  isPassed    Boolean  @default(false)
  answersJson String?  @db.Text // 학생이 기입해 제출한 답안지 원본 (단답/서술형 백업용)
  submittedAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

// --- 9. 수료증 발급 ---
model Certificate {
  id          String   @id @default(cuid())
  certNumber  String   @unique // 수료증 고유 번호
  issuedAt    DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// --- 10. 기기 접속 로그 및 IP 보안 ---
model AccessLog {
  id        String   @id @default(cuid())
  ipAddress String
  userAgent String
  createdAt DateTime @default(now())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- 11. 과제 및 결과물 제출 시스템 ---
model Assignment {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  imageUrl    String?  @db.Text // 과제 설명용 이미지 URL
  fileUrl     String?  @db.Text // 과제 설명용 참고 첨부파일 URL
  createdAt   DateTime @default(now())
  
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id           String   @id @default(cuid())
  fileUrl      String   @db.Text // 학생이 제출한 결과물 문서 파일 URL
  fileName     String   // 표시용 원본 파일 이름
  score        Int?     // 채점 점수 (NULL 가능, 강사 채점 대기)
  feedback     String?  @db.Text // 강사 피드백
  submittedAt  DateTime @default(now())
  
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}
